---
import content from '../data/content.json';
import Icon from './Icon.astro';
const services = content.services;
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="font-display font-bold text-xl sm:text-2xl nav-logo text-white transition-colors duration-300">
        {content.shortName}
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8">
        {content.nav.map((item) => (
          item.dropdown ? (
            <div class="relative group">
              <a href={item.href} class="nav-link text-white opacity-90 hover:opacity-100 transition-all duration-300 font-medium text-sm uppercase tracking-wider flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[240px]">
                  {services.map((service) => (
                    <a href={`/services#${service.id}`} class="flex items-center gap-2.5 px-4 py-2.5 text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors text-sm font-medium">
                      <Icon name={service.icon} class="w-4 h-4 text-gray-400" />
                      {service.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="nav-link text-white opacity-90 hover:opacity-100 transition-all duration-300 font-medium text-sm uppercase tracking-wider">
              {item.label}
            </a>
          )
        ))}
        <a href={content.contact.phoneClick} class="nav-cta bg-brand-600 hover:bg-brand-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all hover:shadow-lg">
          {content.contact.phoneDisplay}
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white p-2 nav-toggle" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white shadow-xl border-t">
    <div class="px-4 py-4 space-y-1">
      {content.nav.map((item) => (
        item.dropdown ? (
          <div>
            <a href={item.href} class="block px-3 py-3 text-gray-800 font-semibold text-base">{item.label}</a>
            <div class="pl-6 space-y-0.5">
              {services.map((service) => (
                <a href={`/services#${service.id}`} class="block px-3 py-2 text-gray-600 hover:text-brand-700 text-sm">
                  {service.name}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="block px-3 py-3 text-gray-800 font-semibold text-base hover:text-brand-700">{item.label}</a>
        )
      ))}
      <div class="pt-3 border-t">
        <a href={content.contact.phoneClick} class="block bg-brand-600 text-white text-center py-3 rounded-lg font-semibold">
          Call {content.contact.phoneDisplay}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  /* Nav scroll states managed via data attribute instead of class toggling */
  header[data-scrolled="true"] {
    background: white;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }
  header[data-scrolled="true"] .nav-logo {
    color: #111827 !important;
  }
  header[data-scrolled="true"] .nav-link {
    color: #374151 !important;
    opacity: 1 !important;
  }
  header[data-scrolled="true"] .nav-link:hover {
    color: #15803d !important;
  }
  header[data-scrolled="true"] .nav-toggle {
    color: #374151 !important;
  }
</style>
