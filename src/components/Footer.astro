---
import content from '../data/content.json';
const c = content.contact;
const hours = content.hours;
const social = content.social;
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 grain-overlay relative">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
 <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
 <!-- Company -->
 <div>
 <a href="/" class="font-display text-xl font-bold text-white mb-4 block">{content.shortName}</a>
 <p class="text-gray-400 text-sm leading-relaxed mb-4">{content.tagline}</p>
 <!-- Social links -->
 <div class="flex gap-3">
 {social.facebook && (
 <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-brand-600 flex items-center justify-center transition-colors" aria-label="Facebook">
 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
 </a>
 )}
 {social.instagram && (
 <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-brand-600 flex items-center justify-center transition-colors" aria-label="Instagram">
 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
 </a>
 )}
 {social.google && (
 <a href={social.google} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-brand-600 flex items-center justify-center transition-colors" aria-label="Google Business">
 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
 </a>
 )}
 {social.yelp && (
 <a href={social.yelp} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-brand-600 flex items-center justify-center transition-colors" aria-label="Yelp">
 <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.895-4.247c.564-.83 1.86-.478 1.86.508v3.936zm-8.793 4.14l1.677-4.89c.336-.98 1.776-.876 1.956.14l.936 5.28c.18 1.02-.84 1.8-1.74 1.332l-2.616-1.38c-.576-.3-.648-1.08-.213-1.482zM8.4 15.96l4.92-1.62c.984-.324 1.74.756 1.14 1.632l-2.88 4.2c-.6.876-1.968.396-1.896-.66l.144-2.724c.024-.36-.108-.648-.428-.828zM4.98 12c0 .564.468 1.02 1.032 1.02h5.508c.984 0 1.476-1.188.78-1.884L7.596 6.6c-.696-.696-1.884-.204-1.884.78V12z"/></svg>
 </a>
 )}
 </div>
 </div>

 <!-- Services -->
 <div>
 <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Services</h3>
 <ul class="space-y-2">
 {content.services.map((s) => (
 <li>
 <a href={`/services#${s.id}`} class="text-gray-400 hover:text-brand-400 text-sm transition-colors">{s.name}</a>
 </li>
 ))}
 </ul>
 </div>

 <!-- Service Area -->
 <div>
 <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Service Area</h3>
 <p class="text-gray-400 text-sm leading-relaxed mb-4">{c.serviceArea}</p>
 <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Hours</h3>
 <p class="text-gray-400 text-sm">{hours.weekdays}</p>
 <p class="text-gray-400 text-sm">{hours.saturday}</p>
 <p class="text-gray-400 text-sm">{hours.sunday}</p>
 </div>

 <!-- Contact -->
 <div>
 <h3 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contact</h3>
 <ul class="space-y-3 text-sm">
 <li>
 <a href={c.phoneClick} class="text-gray-400 hover:text-brand-400 transition-colors">{c.phoneDisplay}</a>
 </li>
 <li>
 <a href={`mailto:${c.email}`} class="text-gray-400 hover:text-brand-400 transition-colors break-all">{c.email}</a>
 </li>
 <li class="text-gray-400">{c.address}</li>
 </ul>
 </div>
 </div>

 <!-- Bottom bar -->
 <div class="mt-12 pt-8 border-t border-gray-700 text-center">
 <p class="text-gray-500 text-sm">&copy; {currentYear} {content.footer.copyright}</p>
 </div>
 </div>
</footer>
